# NewAPI Guard 与 NewAPI 联合部署环境变量模板
#
# 说明：
# 1. Guard 当前不会自动读取 .env 文件，它只读取进程环境变量。
# 2. 如果使用 Docker Compose，本文件既可以作为 Compose 变量模板，
#    也可以通过 environment 注入到容器中。
# 3. 下方分为三类：
#    - Compose 编排本身需要的变量
#    - Guard 当前代码真正支持的环境变量
#    - Guard 当前还不支持环境变量、只能去后台设置的配置项

# -------------------------------------------------------------------
# Docker Compose 编排变量
# -------------------------------------------------------------------
COMPOSE_PROJECT_NAME=newapi-guard
TZ=Asia/Shanghai

# Guard 镜像地址
# 建议使用 GitHub Action 手动构建并推送到 GHCR 后，再在这里填写
GUARD_IMAGE=ghcr.io/your-name/newapi-guard:latest

# NewAPI 官方镜像地址
NEWAPI_IMAGE=calciumion/new-api:latest
NEWAPI_PORT=3000
NEWAPI_NODE_NAME=new-api-node-1

GUARD_PORT=9000

# -------------------------------------------------------------------
# 以下变量是给 NewAPI 常见外部依赖准备的
# 当前模板会把 PostgreSQL / Redis 一起编排进去，但它们不是 Guard 必需组件
# 如果你的 NewAPI 部署方式不需要它们，可以忽略或自行调整 compose
# -------------------------------------------------------------------
POSTGRES_USER=root
POSTGRES_PASSWORD=change-me
POSTGRES_DB=new-api

REDIS_PASSWORD=change-me

# -------------------------------------------------------------------
# Guard 必填：至少补这几项，才能正常进入控制面板并连接 NewAPI
# -------------------------------------------------------------------
GUARD_ADMIN_PASSWORD=change-me
GUARD_NEWAPI_URL=http://new-api:3000

# 说明：
# - 这个值建议在你完成 NewAPI 初始化、拿到管理员令牌后再补上。
# - 如果留空，Guard 仍可启动，但用户管理、签到补发、封禁同步等功能会受限。
GUARD_NEWAPI_ADMIN_TOKEN=

# -------------------------------------------------------------------
# Guard 可选运行参数：以下变量当前代码会直接读取
# -------------------------------------------------------------------
GUARD_LISTEN_ADDR=:9000
GUARD_DATA_DIR=/app/data
GUARD_DB_PATH=/app/data/guard.db
GUARD_WEB_DIR=/app/web
GUARD_SESSION_TTL=24h
GUARD_TOKEN_CACHE_TTL=5m
GUARD_ENABLE_SCHEDULER=true

# -------------------------------------------------------------------
# 以下是 Guard 当前“不会”从环境变量读取的配置项
# 需要在 /guard/admin/ 后台里设置，或提前写入 SQLite config 表
# -------------------------------------------------------------------
# public_base_url=
# oauth_client_id=
# oauth_client_secret=
# oauth_provider_slug=guard-discord
# oauth_state_ttl_seconds=300
# oauth_code_ttl_seconds=120
# oauth_token_ttl_seconds=600
# discord_client_id=
# discord_client_secret=
# discord_guild_id=
# discord_oauth_scopes=["identify","guilds.members.read"]
# discord_access_policy={"logic":"and","conditions":[],"groups":[]}
# rpm_limit=3
# ua_ban_strikes=3
# allowed_ua=[]  # 留空表示不启用 UA 白名单
# checkin_quota=500000
# checkin_threshold=200000
